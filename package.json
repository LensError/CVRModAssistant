{
  "name": "cvr-mod-assistant",
  "version": "1.0.4",
  "description": "Mod manager for ChilloutVR",
  "main": "main.js",
  "scripts": {
    "start": "node_modules\\electron\\dist\\electron.exe .",
    "start:linux": "node_modules/.bin/electron .",
    "dev": "node_modules\\electron\\dist\\electron.exe . --inspect",
    "dev:linux": "node_modules/.bin/electron . --inspect",
    "build": "node node_modules/electron-builder/cli.js --win",
    "build:linux": "node node_modules/electron-builder/cli.js --linux"
  },
  "build": {
    "appId": "com.lenserror.cvr-mod-assistant",
    "productName": "CVR Mod Assistant",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "dll-parser.js",
      "renderer/**/*"
    ],
    "win": {
      "icon": "renderer/assets/icons/icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "CVRModAssistant_Setup.${ext}",
      "perMachine": false,
      "installerHeaderIcon": "renderer/assets/icons/icon.ico"
    },
    "portable": {
      "artifactName": "CVRModAssistant.${ext}"
    },
    "linux": {
      "icon": "renderer/assets/icons/icon.png",
      "category": "Game",
      "target": [
        "AppImage",
        "deb",
        "pacman"
      ],
      "artifactName": "CVRModAssistant_Linux.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "LensError",
      "repo": "CVRModAssistant"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LensError/CVRModAssistant.git"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "electron-updater": "^6.8.3",
    "v8-compile-cache": "^2.3.0",
    "winreg": "^1.2.4"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1"
  },
  "author": { "name": "LensError", "email": "lenserror@gmail.com" },
  "license": "MIT"
}